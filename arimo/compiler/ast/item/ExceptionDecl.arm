package arimo.compiler.ast.item;

import arimo.compiler.ast.decl.FieldDecl;
import arimo.compiler.ast.decl.MethodDecl;
import arimo.compiler.ast.decl.ConstructorDecl;

public class ExceptionDecl {
    public vis      : Integer;
    public isManual : Boolean;
    public name     : String;
    public extends_ : String;
    public fields   : List<FieldDecl>;
    public ctor     : ConstructorDecl;
    public methods  : List<MethodDecl>;

    public constructor(vis: Integer, name: String, extends_: String) {
        this.vis      = vis;
        this.isManual = false;
        this.name     = name;
        this.extends_ = extends_;
        this.fields   = List();
        this.methods  = List();
    }
}
