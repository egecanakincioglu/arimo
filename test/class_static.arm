package test;

// Static method test
public class StaticMethods {
    public static add(a: Integer, b: Integer) : Integer {
        return a + b;
    }

    public static mul(a: Integer, b: Integer) : Integer {
        return a * b;
    }

    public static main() : Void {
        Integer r1 = StaticMethods.add(3, 4);
        IO.println(r1);
        Integer r2 = StaticMethods.mul(5, 6);
        IO.println(r2);
    }
}